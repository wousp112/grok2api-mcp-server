# Required: Your Grok API endpoint (from grok2api or compatible service)
GROK_API_URL=http://your-server:8000/v1

# Required: API key for authentication
GROK_API_KEY=your-api-key-here

# Optional: Grok model to use
# Example: GROK_MODEL=grok-4.20-beta

# Optional: Per-attempt request timeout in ms (default: 90000)
# GROK_REQUEST_TIMEOUT_MS=90000

# Optional: Max retry attempts for failed requests (default: 2)
# GROK_MAX_RETRIES=2

# Optional: Base backoff delay in ms for retries (default: 800)
# GROK_BACKOFF_BASE_MS=800

# Optional: Read timeout in ms (axios timeout, default: same as GROK_REQUEST_TIMEOUT_MS)
# GROK_READ_TIMEOUT_MS=90000

# Optional: Total wall-clock budget across retries (default: 110000)
# GROK_TOTAL_TIMEOUT_MS=110000

# Optional: when set, run as an HTTP MCP server on this port instead of stdio
# GROK_MCP_HTTP_PORT=8787

# Optional: write debug lifecycle logs to this file
# GROK_MCP_DEBUG_LOG=/tmp/grok-mcp.log
