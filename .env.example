# Required: Your Grok API endpoint (from grok2api or compatible service)
GROK_API_URL=http://your-server:8000/v1

# Required: API key for authentication
GROK_API_KEY=your-api-key-here

# Optional: Grok model to use (default: grok-3)
# GROK_MODEL=grok-3

# Optional: Request timeout in ms (default: 60000)
# GROK_REQUEST_TIMEOUT_MS=60000

# Optional: Max retry attempts for failed requests (default: 2)
# GROK_MAX_RETRIES=2

# Optional: Base backoff delay in ms for retries (default: 800)
# GROK_BACKOFF_BASE_MS=800

# Optional: Connection timeout in ms (default: 10000)
# GROK_CONNECT_TIMEOUT_MS=10000

# Optional: Read timeout in ms (default: same as GROK_REQUEST_TIMEOUT_MS)
# GROK_READ_TIMEOUT_MS=60000
